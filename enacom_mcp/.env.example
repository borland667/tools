# ENACOM MCP server configuration
# Copy to .env and fill in. .env is gitignored.

# Path to the Excel tracker. Generate one with:
#   python -m enacom_mcp.scripts.make_tracker --cuit ... --razon-social ... --output ./tracker.xlsx
ENACOM_TRACKER_PATH=

# Where Playwright screenshots and Hertz exports are saved.
ENACOM_ARTIFACTS_DIR=./artifacts

# Browser visibility. true = visible (you can intervene); false = headless.
# Recommended: true. You log into TAD with your AFIP clave fiscal manually.
ENACOM_HEADED=true

# Safety switch. true = fill forms but DO NOT click final "Enviar".
# Flip to false only after a few successful dry runs.
ENACOM_DRY_RUN=true

# Your CUIT (used to match the representado in Hertz; not stored anywhere).
ENACOM_CUIT=
ENACOM_RAZON_SOCIAL=

# Boilerplate "Fundamento" text. Edit to match your situation.
ENACOM_FUNDAMENTO=

# Optional: Playwright storage state path. Leave empty to require manual login each run.
ENACOM_STORAGE_STATE=
